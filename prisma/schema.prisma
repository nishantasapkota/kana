  provider = "postgresql"
  url      = "postgresql://neondb_owner:npg_wNW4JE5uajAk@ep-autumn-mouse-aoz6wq3k.c-2.ap-southeast-1.aws.neon.tech/neondb?sslmode=require"
}

model KanaCharacter {
  id       Int    @id @default(autoincrement())
  char     String
  romaji   String
  kanaType String
  group    String

  @@unique([char, kanaType])
  @@index([kanaType])
}

model KanaSentence {
  id             Int      @id @default(autoincrement())
  text           String
  reading        String
  meaning        String
  kanaType       String
  missingIndices String
  blanks         String
  createdAt      DateTime @default(now())

  @@index([kanaType])
}